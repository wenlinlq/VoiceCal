# DeepSeek API
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# DashScope API (ASR / TTS)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Database
DATABASE_URL=postgresql+asyncpg://voicecal:voicecal@localhost:5432/voicecal

# Redis
REDIS_URL=redis://localhost:6379/0
MEMORY_KEY_PREFIX=voice_calendar
MEMORY_SHORT_TTL_SECONDS=86400

# Memory
MEMORY_AGENT_NAME=VoiceCalendarAgent
MEMORY_LLM_MODEL=qwen3.7-max
MEMORY_EMBEDDING_MODEL=text-embedding-v3
MEM0_API_KEY=
MEM0_VECTOR_STORE=milvus
MEM0_LLM_PROVIDER=
MEM0_EMBEDDING_PROVIDER=
MEM0_ON_DISK=false
OPENAI_API_KEY=
MILVUS_URL=http://localhost:19531
MILVUS_TOKEN=
MILVUS_DB_NAME=
MILVUS_COLLECTION_NAME=voice_calendar_memories
MILVUS_EMBEDDING_DIMS=1024
MILVUS_METRIC_TYPE=COSINE

# App
APP_ENV=development
DEBUG=true
